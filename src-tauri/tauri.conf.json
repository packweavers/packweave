{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "packweave",
  "version": "0.1.1",
  "identifier": "com.packweave",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "packweave",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4NkY0RTUzN0REOTMzQTMKUldTak05bDlVMDV2eU1DWlI1a240QnlXZ3RyUWRBank5NGZ6LzZ4Tlp4dEhiUTlhTXI5NjV0V2MK",
      "endpoints": [
        "https://update.packweave.com/latest.json"
      ]
    }
  }
}
